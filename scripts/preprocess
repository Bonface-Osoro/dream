import configparser
import os
import warnings
import pandas as pd
from dream.pre_geo import shp_to_csv

pd.options.mode.chained_assignment = None
warnings.filterwarnings('ignore')

CONFIG = configparser.ConfigParser()
CONFIG.read(os.path.join(os.path.dirname(__file__), 'script_config.ini'))
BASE_PATH = CONFIG['file_locations']['base_path']

DATA_RAW = os.path.join(BASE_PATH, 'raw')
DATA_PROCESSED = os.path.join(BASE_PATH, '..', 'results', 'processed')
DATA_RESULTS = os.path.join(BASE_PATH, '..', 'results', 'final')
in_folder = os.path.join(DATA_RAW)
out_folder = os.path.join(DATA_PROCESSED)

if __name__ == '__main__':

    shp_to_csv('incidence_rate', in_folder, out_folder)
    shp_to_csv('parasite_rate', in_folder, out_folder)
    shp_to_csv('net_use', in_folder, out_folder)
    shp_to_csv('net_access', in_folder, out_folder)